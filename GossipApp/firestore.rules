rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAnonId(id) {
      return id is string && id.size() > 0;
    }

    // Groups: Minimal metadata (no PII)
    match /artifacts/{appId}/public/data/groups/{groupId} {
      // Anyone can read public groups
      allow read: if true;
      
      // Authenticated users can create groups
      allow create: if isSignedIn() 
                    && request.resource.data.keys().hasAll(['groupId', 'groupName', 'type', 'creatorAnonId', 'rules', 'memberAnonIds'])
                    && request.resource.data.memberAnonIds is list
                    && request.resource.data.creatorAnonId is string;
      
      // Members can update (e.g., joining, leaving)
      allow update: if isSignedIn()
                    && (
                      // Allow adding self to memberAnonIds for public groups
                      (resource.data.type == 'public') ||
                      // Allow moderators to update
                      (request.auth.uid in resource.data.moderators)
                    );
      
      // Only creator can delete
      allow delete: if isSignedIn() 
                    && request.auth.uid == resource.data.creatorAnonId;
    }

    // Join Requests
    match /artifacts/{appId}/public/data/join_requests/{requestId} {
      // Anyone can read their own requests or requests for groups they moderate
      allow read: if isSignedIn();
      
      // Users can create join requests
      allow create: if isSignedIn()
                    && request.resource.data.requesterAnonId is string;
      
      // Moderators can update (approve/reject)
      allow update: if isSignedIn();
      
      allow delete: if isSignedIn();
    }

    // Transient Messages (Group Chat)
    match /transient_messages/{messageId} {
      // Anyone authenticated can read messages
      allow read: if isSignedIn();
      
      // Anyone authenticated can create messages
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['senderAnonId', 'target', 'messageType', 'content', 'timestamp'])
                    && request.resource.data.senderAnonId is string
                    && request.resource.data.messageType in ['text', 'media', 'sticker', 'voice'];
      
      // Anyone can delete (for cleanup)
      allow delete: if isSignedIn();
      
      // No updates allowed
      allow update: if false;
    }

    // Transient DM Messages
    match /transient_dm/{channelId} {
      // Anyone authenticated can read
      allow read: if isSignedIn();
      
      // Anyone authenticated can create
      allow create: if isSignedIn()
                    && request.resource.data.senderAnonId is string;
      
      // Anyone can delete (for cleanup)
      allow delete: if isSignedIn();
      
      // No updates allowed
      allow update: if false;
    }

    // Voice Sessions (Transient signaling)
    match /transient_voice_sessions/{sessionId} {
      // Anyone authenticated can read
      allow read: if isSignedIn();
      
      // Anyone authenticated can create
      allow create: if isSignedIn()
                    && request.resource.data.participants is list;
      
      // Anyone can update (for WebRTC signaling)
      allow update: if isSignedIn();
      
      // Anyone can delete (for cleanup)
      allow delete: if isSignedIn();
    }

    // User Profiles (Optional - for discovery features)
    // NOTE: We don't store user profiles on server by default
    match /artifacts/{appId}/public/data/users/{userId} {
      // Anyone can read (contains only anonId and avatar, no PII)
      allow read: if true;
      
      // Users can create/update their own profile
      allow create, update: if isSignedIn()
                            && request.resource.data.anonId is string
                            && !request.resource.data.keys().hasAny(['phoneNumber', 'email', 'realName']);
      
      // Users can delete their own profile
      allow delete: if isSignedIn();
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
